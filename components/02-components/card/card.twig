{#
/**
 * @file
 * Card Component
 *
 * A flexible card component with title, image, and description.
 *
 * Available props:
 * - title: Card title (required)
 * - image: Image object with url, alt, width, height
 * - text: Card description text
 * - link: Optional link object with url, title, target
 */
#}

{% set attributes = create_attribute() %}

{% set classes = [
  'me-card',
] %}

<div {{attributes.addClass(classes)}}>
  <div class="me-card__body">
    <h3 class="me-card__title">{{ title }}</h3>
    {% if text %}
      <div class="me-card__text">
        {{ text }}
      </div>
    {% endif %}

    {% if link %}
      <a class="me-card__link" href="{{ link.url }}">
        {{ link.text }}
      </a>
    {% endif %}
  </div>
</div>
