{#
/**
 * @file
 * Default theme implementation to display a Text Paragraph.
 *
 * Available variables:
 * - No additional variables are available for this template.
 *
 * @see template_preprocess_paragraph()
 * @ingroup themeable
 */
#}

{% extends 'paragraph.html.twig' %}

{% set rendered_content = content|without(
  'field_me_test_text'
) %}

{% block content %}
  {% embed 'mercury_editor_demo:text' with {
    content,
  } only %}
    {% block content %}
      {{ content.field_me_test_text|field_value }}
    {% endblock %}
  {% endembed %}

  {{ rendered_content }}
{% endblock %}