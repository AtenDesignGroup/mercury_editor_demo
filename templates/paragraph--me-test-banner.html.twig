{#
/**
 * @file
 * Default theme implementation to display a Banner Paragraph.
 *
 * Available variables:
 * - No additional variables are available for this template.
 *
 * @see template_preprocess_paragraph()
 * @ingroup themeable
 */
#}

{% extends 'paragraph.html.twig' %}

{% set rendered_content = content|without(
  'field_me_test_heading',
  'field_me_test_text',
) %}

{% block content %}
  {{ include('mercury_editor_demo:banner', {
    heading: content.field_me_test_heading|field_value|default(''),
    text: content.field_me_test_text|field_value,
  }, with_context = false) }}

  {{ rendered_content }}
{% endblock %}