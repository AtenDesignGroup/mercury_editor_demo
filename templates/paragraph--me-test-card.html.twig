{#
/**
 * @file
 * Default theme implementation to display a Card Paragraph.
 *
 * Available variables:
 * - No additional variables are available for this template.
 *
 * @see template_preprocess_paragraph()
 * @ingroup themeable
 */
#}

{% extends 'paragraph.html.twig' %}

{% set rendered_content = content|without(
  'field_me_test_title',
  'field_me_test_text',
  'field_me_test_link',
) %}

{% set card_link_url = content.field_me_test_link[0]['#url'].toString() ?? '' %}
{% set card_link_text = content.field_me_test_link[0]['#title'] ?? '' %}

{% block content %}
  {{ include('mercury_editor_demo:card', {
    heading: content.field_me_test_title|field_value,
    text: content.field_me_test_text|field_value,
    link: {
      href: card_link_url,
      text: card_link_text,
    },
  }, with_context = false) }}

  {{ rendered_content }}
{% endblock %}
