{#
/**
 * @file
 * Default theme implementation to display a Featured Card Paragraph.
 *
 * Available variables:
 * - No additional variables are available for this template.
 *
 * @see template_preprocess_paragraph()
 * @ingroup themeable
 */
#}

{% extends 'paragraph.html.twig' %}

{% set rendered_content = content|without(
  'field_me_test_heading',
  'field_me_test_media',
  'field_me_test_link',
) %}

{% set featured_card_link = content.field_me_test_link|field_value[0]['#url'] ?? null %}

{% block content %}
  {{ include('mercury_editor_demo:featured-card', {
    media: content.field_me_test_media|field_value,
    heading: content.field_me_test_heading|field_value|default(''),
    href: featured_card_link,
  }, with_context = false) }}

  {{ rendered_content }}
{% endblock %}
