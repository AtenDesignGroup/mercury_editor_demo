<?php

/**
 * @file
 * Module hooks for Mercury Editor Demo module.
 */

use Drupal\field\Entity\FieldConfig;
use Drupal\field\Entity\FieldStorageConfig;

/**
 * Implements hook_entity_type_alter().
 */
function mercury_editor_demo_entity_type_alter(array &$entity_types) {
  // Add validation constraint to the node entity.
  $entity_types['node']->addConstraint('InvalidTitle');
}

/**
 * Implements hook_page_attachments().
 */
function mercury_editor_demo_page_attachments(array &$attachments) {
  $attachments['#attached']['library'][] = 'mercury_editor_demo/global';
}

/**
 * Implements hook_library_info_alter().
 */
function mercury_editor_demo_library_info_alter(array &$libraries, $extension) {
  if ($extension === 'mercury_editor' && isset($libraries['menu'])) {
    $libraries['menu']['dependencies'][] = 'mercury_editor_demo/component_menu';
    $libraries['menu']['dependencies'][] = 'mercury_editor_demo/card';
  }
}

/**
 * Implements hook_theme().
 */
function mercury_editor_demo_theme($existing, $type, $theme, $path) {
  $themes = [];
  $template_dir = $path . '/templates';

  // Auto-discover all paragraph templates in the templates directory.
  if (is_dir($template_dir)) {
    $files = scandir($template_dir);
    foreach ($files as $file) {
      // Look for paragraph--*.html.twig files.
      if (preg_match('/^paragraph--(.+)\.html\.twig$/', $file, $matches)) {
        $template_name = $matches[1];
        $theme_hook = 'paragraph__' . str_replace('-', '_', $template_name);

        $themes[$theme_hook] = [
          'base hook' => 'paragraph',
          'template' => 'paragraph--' . $template_name,
          'path' => $template_dir,
        ];
      }

      if (preg_match('/^node--(.+)\.html\.twig$/', $file, $matches)) {
        $template_name = $matches[1];
        $theme_hook = 'node__' . str_replace('-', '_', $template_name);

        $themes[$theme_hook] = [
          'base hook' => 'node',
          'template' => 'node--' . $template_name,
          'path' => $template_dir,
        ];
      }
    }
  }

  return $themes;
}

/**
 * Implements hook_preprocess_layout().
 *
 * Removes empty regions from Layout Discovery layouts so their wrappers are
 * not rendered when no content has been placed in them. Only applies during
 * Mercury Editor preview (edit mode).
 */
function mercury_editor_demo_preprocess_layout(&$variables) {
  if (\Drupal::service('mercury_editor.context')->isPreview()) {
    return;
  }

  foreach (array_keys($variables['region_attributes']) as $region) {
    if (isset($variables['content'][$region]) && empty(\Drupal\Core\Render\Element::children($variables['content'][$region]))) {
      unset($variables['content'][$region]);
    }
  }
}

/**
 * Preprocess Paragraph
 * Implements hook_preprocess_paragraph().
 * @param $variables
 * @return void
 */
function mercury_editor_demo_preprocess_paragraph(&$variables) {
  /** @var \Drupal\paragraphs\Entity\Paragraph $paragraph */
  $paragraph = $variables['paragraph'];
  $behaviorSettings = $paragraph->getAllBehaviorSettings();

  // Set style option behaviors as a logical template variable.
  if (!empty($behaviorSettings['style_options'])) {
    if (!isset($variables['style_options'])) {
      $variables['style_options'] = [];
    }

    foreach ($behaviorSettings['style_options'] as $key => $style) {
      if (!empty($style['property'])) {
        $variables['style_options'][$key] = $style['property'];
      }
    }
  }
}

/**
 * Creates a paragraph field for the provided entity type and bundle.
 */
function mercury_editor_demo_make_paragraph_field(
  $entity_type,
  $bundle,
  $field_name,
  $field_label,
  $handler_settings = [],
  $widget = 'paragraphs',
  $formatter = 'entity_reference_revisions_entity_view',
  $extra_settings = [],
) {

  if (empty($handler_settings)) {
    $handler_settings = [
      'target_bundles' => NULL,
      'negate' => TRUE,
    ];
  }
  $field_storage = FieldStorageConfig::loadByName($entity_type, $field_name);
  if (!$field_storage) {
    // Add a paragraphs field.
    $field_storage = FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => $entity_type,
      'type' => 'entity_reference_revisions',
      'cardinality' => '-1',
      'settings' => [
        'target_type' => 'paragraph',
      ],
    ]);
    $field_storage->save();
  }
  $field_config = FieldConfig::loadByName($entity_type, $bundle, $field_name);
  if (!$field_config) {
    $field = FieldConfig::create([
      'field_storage' => $field_storage,
      'bundle' => $bundle,
      'label' => $field_label,
      'settings' => [
        'handler' => 'default:paragraph',
        'handler_settings' => $handler_settings,
      ],
    ]);
    $field->save();
  }

  $form_display = \Drupal::service('entity_display.repository')->getFormDisplay($entity_type, $bundle);
  $form_display->setComponent($field_name, ['type' => $widget] + $extra_settings);
  $form_display->save();

  $view_display = \Drupal::service('entity_display.repository')->getViewDisplay($entity_type, $bundle);
  $view_display->setComponent($field_name, ['type' => $formatter, 'label' => 'hidden'] + $extra_settings);
  $view_display->save();
}
